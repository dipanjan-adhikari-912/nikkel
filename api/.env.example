# Nikkel API — Required environment variables

# Supabase project URL (e.g. https://your-project.supabase.co)
SUPABASE_URL=

# Supabase service_role key (found in Supabase Dashboard → Settings → API → service_role key)
# WARNING: Keep this secret. Never commit it or expose it client-side.
SUPABASE_SERVICE_KEY=

# Port the API server listens on (default for dev: 3001)
PORT=3001
