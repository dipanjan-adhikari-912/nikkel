# Nikkel Web Viewer — Environment variables

# Chrome Web Store URL (optional). Set this when published to the store.
# The download page will link here instead of showing side-loading instructions.
# Example: https://chromewebstore.google.com/detail/nikkel/xxxxxxxxxx
NEXT_PUBLIC_CHROME_STORE_URL=

# Supabase — must be set in Vercel dashboard
# SUPABASE_URL (server-side)
# SUPABASE_SERVICE_KEY (server-side)

# Client-side Supabase (for native web login). Use the same Supabase project as the extension.
# NEXT_PUBLIC_SUPABASE_URL=https://ptyogubndwyanjaenmzy.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_rIIjNoFOiD5H7qhJMUPO3Q_Sjr9rsdl
