# Nikkel Web Viewer — Required environment variables

# URL of the Nikkel API server (e.g. https://nikkel-wheat.vercel.app)
# For local development with `npm run dev` in the web directory, set to http://localhost:3000
NEXT_PUBLIC_API_URL=

# Chrome Web Store URL (optional). Set this when published to the store.
# The download page will link here instead of showing side-loading instructions.
# Example: https://chromewebstore.google.com/detail/nikkel/xxxxxxxxxx
NEXT_PUBLIC_CHROME_STORE_URL=
